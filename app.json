{
  "expo": {
    "name": "Dunex",
    "slug": "dunex-markets",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "dunexmarkets",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dunex.markets",
      "infoPlist": {
        "NSContactsUsageDescription": "Dunex requires access to your contacts to facilitate secure network invitations and transfers.",
        "NSCameraUsageDescription": "Dunex requires camera access to scan documents for KYC verification.",
        "NSPhotoLibraryUsageDescription": "Dunex requires access to your photos to upload secure payment receipts.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.dunex.markets",
      "permissions": [
        "android.permission.READ_CONTACTS",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/images/icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "asyncRoutes": {
            "web": true,
            "default": "development"
          }
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000000",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Dunex requires access to your photos to upload secure payment receipts.",
          "cameraPermission": "Dunex requires camera access to scan documents for KYC verification."
        }
      ],
      [
        "expo-contacts",
        {
          "contactsPermission": "Dunex requires access to your contacts to facilitate secure network invitations and transfers."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2e4d4440-910d-47f9-9db8-8b70b400d5eb"
      }
    }
  }
}